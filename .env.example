# FILE: customer_support_rag/.env.example
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── LLM Provider ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-api-key-here...
LLM_MODEL_NAME=gpt-4o
LLM_PROVIDER=openai                         # Switch to "ollama" for local inference
LLM_TEMPERATURE=0.0

# ── Cohere (Reranker) ─────────────────────────────────────────────────────────
COHERE_API_KEY=...your-cohere-api-key-here...
RERANKER_TOP_N=5                            # Number of results to return after reranking

# ── Ollama (Future Expansion) ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=llama3

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBED_MODEL_NAME=text-embedding-3-small
EMBED_DIMENSIONS=1536

# ── ChromaDB Vector Store ─────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=support_docs

# ── Ingestion ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Agent Configuration ───────────────────────────────────────────────────────
AGENT_MAX_RETRIES=3

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console                          # json (production) | console (development)
