# FILE: customer_support_rag/.env.example
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── LLM Provider ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-api-key-here...
LLM_MODEL_NAME=gpt-4o
LLM_PROVIDER=openai                         # Switch to "ollama" for local inference
LLM_TEMPERATURE=0.0

# ── Cohere (Reranker) ─────────────────────────────────────────────────────────
COHERE_API_KEY=...your-cohere-api-key-here...
RERANKER_TOP_N=5                            # Number of results to return after reranking

# ── Ollama (Future Expansion) ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434      # Port: 11434 (Ollama default)
OLLAMA_MODEL_NAME=llama3

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBED_MODEL_NAME=text-embedding-3-small
EMBED_DIMENSIONS=1536

# ── ChromaDB Vector Store ─────────────────────────────────────────────────────
# Port 8001 — must NOT conflict with API (8000) or Streamlit UI (8501)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=support_docs

# ── Ingestion ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Agent Configuration ───────────────────────────────────────────────────────
AGENT_MAX_RETRIES=3

# ── FastAPI Backend ───────────────────────────────────────────────────────────
# Port 8000 — must NOT conflict with ChromaDB (8001) or Streamlit UI (8501)
API_HOST=0.0.0.0
API_PORT=8000

# CORS: restrict to Streamlit UI origin in production, or keep "*" for dev
# Example production value: http://localhost:8501
CORS_ORIGINS=*

# ── Streamlit UI ──────────────────────────────────────────────────────────────
# Port 8501 — Streamlit default; must NOT conflict with API (8000) or ChromaDB (8001)
# The UI reads API_BASE_URL to know where the FastAPI backend is.
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
API_BASE_URL=http://localhost:8000          # Used by ui/app.py to call the backend

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console                          # json (production) | console (development)
